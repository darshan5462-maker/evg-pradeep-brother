rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /sermons/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /events/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /blogs/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /lessons/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /prayers/{id} {
      allow read, write: if true;
    }
    match /logs/{id} {
      allow read: if true;
      allow write: if true;
    }
    match /settings/{id} {
      allow read, write: if true;
    }
  }
}
